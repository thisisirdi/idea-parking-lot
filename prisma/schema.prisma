generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IdeaStatus {
  INBOX
  PARKED
  EXPLORING
  IN_PROGRESS
  SHIPPED
  ARCHIVED
}

model Idea {
  id             String     @id @default(uuid()) @db.Uuid
  title          String     @db.VarChar(160)
  description    String?    @db.Text
  riceReach      Decimal?   @db.Decimal(10, 2)
  riceImpact     Decimal?   @db.Decimal(10, 2)
  riceConfidence Decimal?   @db.Decimal(10, 2)
  riceEffort     Decimal?   @db.Decimal(10, 2)
  riceScore      Decimal?   @db.Decimal(12, 2)
  status         IdeaStatus @default(INBOX)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

